d1: drift, l=0.05;
d2: drift, l=0.05;
l1: line=(d1, d2);
use, l1;

beam, particle="proton",
        energy=953.27231*MeV,
        distrType="userfile",
        distrFile="../Beams/LhARA_5cm_pm2-rftrack.dat",
        distrFileFormat = "x[m]:y[m]:S[m]:xp[rad]:yp[rad]:E[MeV]";

sample, all;

!option, generatePrimariesOnly=1;
